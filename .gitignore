node_modules/
# scripts/ — one-off Python/shell scripts. Never committed.
scripts/
# context/ is a free-form folder for project-specific files — nothing in it is committed.
context/*
!context/.gitkeep
website/dist/
website/.astro/
# coderepo — drop your project here. Everything is ignored — your code is never committed.
# To use your own codebase locally: drop it into coderepo/ — git will ignore it automatically.
# NEVER add a !coderepo/<your-codebase> exception here.
coderepo/*
!coderepo/README.md
.DS_Store
**/.DS_Store
PROJECT.md
# Generated PDFs are never committed
*.pdf
artefacts/**
!artefacts/**/
!artefacts/**/.gitkeep
!artefacts/**/sample-*
