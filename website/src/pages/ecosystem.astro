---
import Base from '../layouts/Base.astro';

const projects = [
  { name: 'Agentic DA',    site: 'https://glovarix.github.io/agentic-da/' },
  { name: 'Metaprompter',  site: 'https://binu-alexander.github.io/metaprompter/' },
  { name: 'fmRouter',      site: 'https://glovarix.github.io/fmRouter/' },
];
---

<Base title="More">
  <div class="mx-auto max-w-4xl px-6 py-20">
    <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">More</h1>
    <div class="mt-8 divide-y divide-zinc-100 dark:divide-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
      {projects.map(p => (
        <a
          href={p.site}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between bg-white px-6 py-4 text-sm font-medium text-zinc-900 transition-colors hover:bg-zinc-50 dark:bg-zinc-900 dark:text-white dark:hover:bg-zinc-800/60 group"
        >
          {p.name}
          <svg class="h-4 w-4 text-zinc-400 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</Base>
