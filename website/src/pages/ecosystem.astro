---
import Base from '../layouts/Base.astro';
import CTA from '../components/CTA.astro';
import Share from '../components/Share.astro';

const projects = [
  {
    icon: '📊',
    name: 'Agentic DA',
    tagline: 'Agentic data analysis harness',
    description: 'The same structured, git-committed approach as Baxter — applied to data analysis workflows, analysis artefacts, and insight documentation.',
    site: 'https://glovarix.github.io/agentic-da/',
    github: 'https://github.com/glovarix/agentic-da',
  },
  {
    icon: '✨',
    name: 'Metaprompter',
    tagline: 'Structured prompt template framework',
    description: 'Takes your messy, one-off prompts and extracts the underlying template — converting them into structured JSON formats that can be saved and shared across teams and applications.',
    site: 'https://binu-alexander.github.io/metaprompter/',
    github: 'https://github.com/binu-alexander/metaprompter',
  },
  {
    icon: '🔀',
    name: 'fmRouter',
    tagline: 'AI playground and evals framework for FileMaker',
    description: 'Create, version, and compare prompts across multiple LLMs with LLM-as-Judge evaluation and full traceability — built natively in FileMaker 2025 without plugins.',
    site: 'https://glovarix.github.io/fmRouter/',
    github: 'https://github.com/glovarix/fmRouter',
  },
];
---

<Base title="More" description="Related tools from the same stable — Agentic DA, Metaprompter, and fmRouter.">
  <div class="border-b border-zinc-200 bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900/50">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <h1 class="text-4xl font-bold text-zinc-900 dark:text-white">Other useful stuff to check out</h1>
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-6 py-16">
    <div class="divide-y divide-zinc-100 dark:divide-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
      {projects.map(p => (
        <div class="flex items-center gap-6 bg-white px-6 py-5 dark:bg-zinc-900">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-zinc-100 text-2xl dark:bg-zinc-800">
            {p.icon}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-baseline gap-2">
              <span class="font-semibold text-zinc-900 dark:text-white">{p.name}</span>
              <span class="text-sm text-zinc-500 dark:text-zinc-400">{p.tagline}</span>
            </div>
            <p class="mt-1 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{p.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <a
                href={p.site}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-900 px-3 py-1.5 text-xs font-semibold text-white transition-colors hover:bg-zinc-700 dark:bg-zinc-700 dark:hover:bg-zinc-600"
              >
                View Site
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
              </a>
              <a
                href={p.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-1.5 text-xs font-semibold text-zinc-700 transition-colors hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-800"
              >
                <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <Share />
  <CTA />
</Base>
