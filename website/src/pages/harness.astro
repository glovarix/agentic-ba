---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import CTA from '../components/CTA.astro';
const base = import.meta.env.BASE_URL;
const site = 'https://www.thedatadrivenlife.com';

const faqs = [
  {
    q: 'What is an AI harness?',
    a: 'An AI harness is a structured layer of instructions, rules, templates, and worked examples that wraps a general-purpose language model and makes it produce dramatically better, more reliable results for a specific job. The model supplies the raw reasoning; the harness supplies the discipline, context, and format.',
  },
  {
    q: 'How is a harness different from an app or a framework?',
    a: 'An app is software you log into, with its own server, database, and account. A framework is a codebase you build on top of. A harness is neither — it is configuration and context (plain files) that you point an existing AI tool at. There is nothing to host, install, or subscribe to; you bring your own model through a tool like Claude Code, Cursor, or GitHub Copilot.',
  },
  {
    q: 'What goes into a harness?',
    a: 'Typically four things: instructions that tell the model its role and how to behave, rules that constrain and route its decisions, templates that give every output a consistent and verifiable structure, and samples — worked examples the model can pattern-match against. Together they turn an open-ended model into a predictable specialist.',
  },
  {
    q: 'Why does a harness improve results so much?',
    a: 'A general model will answer almost anything, but with no house style, no guarantee it checked the facts, and no consistent structure. A harness removes that variance: it forces the model to classify the request, pull the right template, verify claims against a real source of truth, and return output in a shape a human or another system can act on immediately.',
  },
  {
    q: 'Is Baxter an AI harness?',
    a: 'Yes. Baxter is a business-analysis harness. You clone it, drop your codebase into its coderepo/ folder, and point your AI coding assistant at it. It then behaves like a senior business analyst — drafting requirements, test cases, and technical plans, and verifying every one against your real code before you see it.',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DefinedTerm',
      '@id': `${site}${base}harness/#definedterm`,
      name: 'AI harness',
      alternateName: ['agentic harness', 'LLM harness', 'agent harness'],
      description:
        'A structured layer of instructions, rules, templates, and worked examples that wraps a general-purpose AI model and makes it produce dramatically better, more reliable results for a specific task — without any hosted app, server, or account.',
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        name: 'The Agentic BA — glossary',
        url: `${site}${base}harness/`,
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${site}${base}harness/#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}${base}` },
        { '@type': 'ListItem', position: 2, name: 'What is an AI harness?', item: `${site}${base}harness/` },
      ],
    },
  ],
};
---

<Base
  title="What is an AI Harness?"
  description="An AI harness is a layer of instructions, rules, templates, and samples that makes a general-purpose model give dramatically better results. A plain-English definition, what goes into a harness, and how it differs from an app or a framework."
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(structuredData)}
  />

  <PageHeader
    title="What is an AI harness?"
    description="The layer that turns a general-purpose AI model into a disciplined specialist — and why it beats building yet another app."
  />

  <div class="mx-auto max-w-3xl px-6 py-16">
    <div class="space-y-16">

      <!-- Definition -->
      <div>
        <div class="rounded-2xl border border-primary-200 bg-primary-50/60 p-6 dark:border-primary-800/30 dark:bg-primary-900/10">
          <p class="text-xs font-semibold uppercase tracking-wide text-primary-700 dark:text-primary-400">Definition</p>
          <p class="mt-2 text-lg leading-relaxed text-zinc-800 dark:text-zinc-200">
            An <strong>AI harness</strong> is a structured layer of <strong>instructions, rules, templates, and worked samples</strong> that wraps a general-purpose language model and makes it produce ridiculously better, more reliable results for a specific job. The model brings the raw reasoning; the harness brings the discipline, the context, and the format.
          </p>
        </div>
      </div>

      <!-- Why it matters -->
      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">Why a harness beats raw prompting</h2>
        <div class="mt-6 space-y-4 leading-relaxed text-zinc-600 dark:text-zinc-400">
          <p>
            A modern model will answer almost anything you ask. The problem is not capability — it is consistency. Ask the same model for a requirements document twice and you get two different shapes, two different levels of rigour, and no guarantee either one checked its facts.
          </p>
          <p>
            A harness removes that variance. It tells the model exactly what role to play, forces it to classify the request before acting, hands it the right template, and requires it to verify every claim against a real source of truth. The output stops being a plausible-sounding draft and starts being something a human — or another system — can act on immediately.
          </p>
        </div>
      </div>

      <!-- What goes in -->
      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">What goes into a harness</h2>
        <p class="mt-3 leading-relaxed text-zinc-600 dark:text-zinc-400">Four ingredients, working together:</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">
            <div class="text-2xl">📜</div>
            <h3 class="mt-3 font-semibold text-zinc-900 dark:text-white">Instructions</h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">Who the model is, what it is for, and how it should behave — its role and its standing orders.</p>
          </div>
          <div class="rounded-xl border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">
            <div class="text-2xl">⚖️</div>
            <h3 class="mt-3 font-semibold text-zinc-900 dark:text-white">Rules</h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">Constraints and routing logic that decide what the model does with a given request — and what it must never do.</p>
          </div>
          <div class="rounded-xl border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">
            <div class="text-2xl">📐</div>
            <h3 class="mt-3 font-semibold text-zinc-900 dark:text-white">Templates</h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">A consistent, verifiable structure for every output, so results are comparable and reviewable — never ad hoc.</p>
          </div>
          <div class="rounded-xl border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">
            <div class="text-2xl">🧩</div>
            <h3 class="mt-3 font-semibold text-zinc-900 dark:text-white">Samples</h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">Worked examples the model pattern-matches against, so it learns the standard from demonstration, not description.</p>
          </div>
        </div>
      </div>

      <!-- Harness vs app vs framework -->
      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">Harness vs. app vs. framework</h2>
        <div class="mt-6 overflow-hidden rounded-xl border border-zinc-200 dark:border-zinc-700">
          <table class="w-full text-sm">
            <thead class="border-b border-zinc-200 bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900">
              <tr>
                <th class="px-5 py-3 text-left font-semibold text-zinc-900 dark:text-white">Approach</th>
                <th class="px-5 py-3 text-left font-semibold text-zinc-900 dark:text-white">What it is</th>
                <th class="hidden px-5 py-3 text-left font-semibold text-zinc-900 dark:text-white sm:table-cell">What you run</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-100 dark:divide-zinc-800">
              <tr class="bg-white dark:bg-zinc-950">
                <td class="px-5 py-4 font-semibold text-zinc-900 dark:text-white">App</td>
                <td class="px-5 py-4 text-zinc-600 dark:text-zinc-400">Software with its own server, database, and login.</td>
                <td class="hidden px-5 py-4 text-zinc-500 sm:table-cell">A hosted service you subscribe to.</td>
              </tr>
              <tr class="bg-white dark:bg-zinc-950">
                <td class="px-5 py-4 font-semibold text-zinc-900 dark:text-white">Framework</td>
                <td class="px-5 py-4 text-zinc-600 dark:text-zinc-400">A codebase you build on top of and deploy.</td>
                <td class="hidden px-5 py-4 text-zinc-500 sm:table-cell">Your own application, plus infrastructure.</td>
              </tr>
              <tr class="bg-primary-50/40 dark:bg-primary-900/10">
                <td class="px-5 py-4 font-semibold text-primary-700 dark:text-primary-300">Harness</td>
                <td class="px-5 py-4 text-zinc-600 dark:text-zinc-400">Plain files — instructions, rules, templates, samples — that steer a model you already have.</td>
                <td class="hidden px-5 py-4 text-zinc-500 sm:table-cell">An AI tool you already use, pointed at a folder.</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
          The harness is the lightest of the three by design. There is nothing to host, install, or maintain — which is exactly why it is the fastest way to get reliable, specialised output from an AI you already pay for.
        </p>
      </div>

      <!-- Baxter as a harness -->
      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">Baxter is a business-analysis harness</h2>
        <div class="mt-6 space-y-4 leading-relaxed text-zinc-600 dark:text-zinc-400">
          <p>
            Baxter is a concrete example of the idea. It is a harness that turns the AI coding assistant your team already runs — <strong class="text-zinc-900 dark:text-white">Claude Code, Cursor, or GitHub Copilot</strong> — into a senior business analyst.
          </p>
          <p>
            You clone the harness, drop your codebase into its <code class="rounded bg-zinc-100 px-1.5 py-0.5 text-sm dark:bg-zinc-800">coderepo/</code> folder, and point your AI tool at it. From then on, you paste raw client requests — an email, a Slack thread, a voice note — and Baxter drafts the right artefact and checks every word against your real code before you ever see it. Requirements, test cases, bug reports, technical plans: structured, verified, and version-controlled.
          </p>
        </div>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a href={`${base}getting-started/`} class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary-700">
            Get started with Baxter
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href={`${base}philosophy/`} class="inline-flex items-center justify-center rounded-lg border border-zinc-300 px-6 py-3 text-sm font-semibold text-zinc-900 transition-all hover:bg-zinc-50 dark:border-zinc-700 dark:text-white dark:hover:bg-zinc-800">
            Read the philosophy
          </a>
        </div>
      </div>

      <!-- FAQ -->
      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">Frequently asked questions</h2>
        <div class="mt-6 space-y-3">
          {faqs.map((f) => (
            <details class="group rounded-xl border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900">
              <summary class="cursor-pointer list-none font-semibold text-zinc-900 marker:hidden dark:text-white">
                <span class="flex items-center justify-between gap-4">
                  {f.q}
                  <span class="text-primary-600 transition-transform group-open:rotate-45 dark:text-primary-400">+</span>
                </span>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{f.a}</p>
            </details>
          ))}
        </div>
      </div>

    </div>
  </div>

  <CTA />
</Base>
