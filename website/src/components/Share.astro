---
const url = 'https://glovarix.github.io/agentic-ba/';
const text = 'Most dev teams waste time building the wrong things. Baxter is an agentic framework for SDLC knowledge management — paste any raw client request and it classifies, drafts, and runs multi-dimensional sanity checking against your codebase before you review a single word.';
const linkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
const twitterUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(text)}`;
---

<section class="border-t border-zinc-200 py-20 dark:border-zinc-800">
  <div class="mx-auto max-w-2xl px-6 text-center">
    <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400">Spread the word</p>
    <h2 class="mt-3 text-2xl font-bold text-zinc-900 dark:text-white">Know a team that's writing requirements from memory?</h2>
    <p class="mt-3 text-base text-zinc-500 dark:text-zinc-400">Share Baxter with them.</p>

    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">

      <!-- LinkedIn -->
      <a
        href={linkedInUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex w-full items-center justify-center gap-2.5 rounded-lg border border-[#0A66C2] bg-[#0A66C2] px-6 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90 sm:w-auto"
      >
        <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        Share on LinkedIn
      </a>

      <!-- X / Twitter -->
      <a
        href={twitterUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex w-full items-center justify-center gap-2.5 rounded-lg border border-zinc-900 bg-zinc-900 px-6 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90 dark:border-zinc-700 dark:bg-zinc-800 sm:w-auto"
      >
        <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.631L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
        </svg>
        Share on X
      </a>

      <!-- Copy link -->
      <button
        id="copy-link-btn"
        data-url={url}
        class="inline-flex w-full items-center justify-center gap-2.5 rounded-lg border border-zinc-300 bg-white px-6 py-3 text-sm font-semibold text-zinc-700 transition-colors hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:bg-zinc-800 sm:w-auto"
      >
        <svg id="copy-icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
        </svg>
        <span id="copy-label">Copy link</span>
      </button>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('copy-link-btn');
  const label = document.getElementById('copy-label');
  const icon = document.getElementById('copy-icon');

  btn?.addEventListener('click', async () => {
    const url = btn.dataset.url ?? '';
    try {
      await navigator.clipboard.writeText(url);
      label!.textContent = 'Copied!';
      icon!.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />';
      setTimeout(() => {
        label!.textContent = 'Copy link';
        icon!.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />';
      }, 2000);
    } catch {
      label!.textContent = 'Copy failed';
    }
  });
</script>
