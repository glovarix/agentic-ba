---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 dark:border-zinc-800">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={base} class="flex items-center gap-2.5">
          <img src={`${base}agentic-ba-logo.png`} alt="Baxter logo" class="h-9 w-9 rounded-lg object-cover" />
          <span class="text-sm font-semibold text-zinc-900 dark:text-white">The Agentic BA</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
          The Agentic Business Analysis Harness Framework (ABAHF).
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-zinc-900 dark:text-white">Documentation</h4>
        <ul class="mt-3 space-y-2">
          <li><a href={`${base}getting-started/`} class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Get Started</a></li>
          <li><a href={`${base}templates/`} class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Templates</a></li>
          <li><a href={`${base}philosophy/`} class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Philosophy</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-zinc-900 dark:text-white">Community</h4>
        <ul class="mt-3 space-y-2">
          <li><a href="https://github.com/glovarix/agentic-ba/issues" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Issues</a></li>
          <li><a href="https://github.com/glovarix/agentic-ba/discussions" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">Discussions</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-zinc-900 dark:text-white">Resources</h4>
        <ul class="mt-3 space-y-2">
          <li><a href="https://github.com/glovarix/agentic-ba" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-zinc-200 pt-8 dark:border-zinc-800 sm:flex-row">
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        &copy; {year} Baxter — The Agentic BA. Designed by <a href="https://www.thedatadrivenlife.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 hover:text-zinc-900 dark:hover:text-white transition-colors"><img src={`${base}binu-alexander.png`} alt="Dr Binu Alexander" class="h-6 w-6 rounded-full object-cover" />Dr Binu Alexander</a> · <a href="https://www.thedatadrivenlife.com" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-900 dark:hover:text-white transition-colors">thedatadrivenlife.com</a> · MIT Licence
      </p>
      <a
        href="https://github.com/glovarix/agentic-ba"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
      >
        Built with Astro
      </a>
    </div>
  </div>
</footer>
